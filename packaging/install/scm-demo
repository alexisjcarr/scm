#!/usr/bin/env bash
set -euo pipefail

MANIFEST_PATH="${SCM_MANIFEST_PATH:-/usr/local/share/scm/examples/manifests/php-app-single-host.yaml}"
SERVER_ADDRESS="${SCM_SERVER_ADDRESS:-127.0.0.1:8443}"
APPLY_UI_BASE="${SCM_APPLY_UI_BASE:-http://127.0.0.1:8080}"

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required command: $1" >&2
    exit 1
  fi
}

sudo_if_needed() {
  if [[ "${EUID}" -eq 0 ]]; then
    "$@"
  else
    sudo "$@"
  fi
}

check_file() {
  if [[ ! -f "$1" ]]; then
    echo "required file not found: $1" >&2
    exit 1
  fi
}

wait_for_url() {
  local url="$1"
  local label="$2"
  local attempts="${3:-20}"
  local delay="${4:-1}"

  for ((i = 1; i <= attempts; i++)); do
    if curl -fsS "${url}" >/dev/null 2>&1; then
      echo "${label} is ready: ${url}"
      return 0
    fi
    sleep "${delay}"
  done

  echo "timed out waiting for ${label}: ${url}" >&2
  exit 1
}

need curl
need scmctl
need systemctl
check_file /etc/scm/scmctld.yaml
check_file /etc/scm/scmctld-agent.yaml
check_file "${MANIFEST_PATH}"

cat <<'EOF'
Expected /etc/scm/scmctld.yaml
grpc_listen_address: ":8443"
http_listen_address: ":8080"
database_path: "/var/lib/scm/scmctld.db"
agent_auth_tokens:
  demo-host-1-agent: "demo-host-1-token"
log_level: "info"
log_json: false
lease_duration: 2m

Expected /etc/scm/scmctld-agent.yaml
control_plane_address: "127.0.0.1:8443"
state_dir: "/var/lib/scm/scmctld-agent/state"
manifest_cache_dir: "/var/lib/scm/scmctld-agent/manifests"
metrics_listen_address: ":9108"
host_id: "demo-host-1"
agent_id: "demo-host-1-agent"
auth_token: "demo-host-1-token"
labels:
  role: "web"
  env: "demo"
log_level: "info"
log_json: false
poll_interval: 5s
run_timeout: 5m
EOF

sudo_if_needed systemctl reset-failed scmctld scmctld-agent
sudo_if_needed systemctl restart scmctld
sudo_if_needed systemctl restart scmctld-agent
sudo_if_needed systemctl status scmctld --no-pager
sudo_if_needed systemctl status scmctld-agent --no-pager

wait_for_url "http://127.0.0.1:8080" "control plane UI"
wait_for_url "http://127.0.0.1:9108/healthz" "agent health"
wait_for_url "http://127.0.0.1:9108/readyz" "agent readiness"

scmctl validate -f "${MANIFEST_PATH}"
apply_output="$(scmctl apply -f "${MANIFEST_PATH}" --server "${SERVER_ADDRESS}")"
printf '%s\n' "${apply_output}"

apply_id="$(printf '%s\n' "${apply_output}" | sed -n 's/^apply_id=\([^ ]*\).*/\1/p')"
if [[ -z "${apply_id}" ]]; then
  echo "failed to parse apply_id from scmctl output" >&2
  exit 1
fi

cat <<EOF

Apply detail:
  ${APPLY_UI_BASE}/applies/${apply_id}

Watch agent execution:
  journalctl -u scmctld-agent -f -o cat

Verify locally:
  curl -sv http://127.0.0.1/

Verify publicly if ingress is allowed:
  curl -sv http://PUBLIC_IP/
EOF
